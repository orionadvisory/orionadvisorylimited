{
  "name": "orion",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter web dev",
    "dev:admin": "pnpm --filter admin dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:push": "pnpm --filter @orion/db db:push",
    "db:generate": "pnpm --filter @orion/db db:generate",
    "db:migrate": "pnpm --filter @orion/db db:migrate",
    "db:studio": "pnpm --filter @orion/db db:studio",
    "db:seed": "pnpm --filter @orion/db db:seed"
  },
  "devDependencies": {
    "@types/node": "^20",
    "turbo": "^2.3.3",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
